# ─── Database (Supabase PostgreSQL) ───
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── JWT Authentication ───
JWT_SECRET="generate-a-strong-random-secret-min-32-chars"

# ─── Cloudinary (Image uploads) ───
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── MercadoPago (Payments) ───
MERCADOPAGO_ACCESS_TOKEN=""

# ─── Maileroo (Transactional emails) ───
MAILEROO_API_KEY=""
MAILEROO_FROM_EMAIL="pedidos@vladiburger.com"
MAILEROO_FROM_NAME="Vladi.burger"

# ─── External Delivery Platforms (optional) ───
RAPPI_WEBHOOK_SECRET=""
PEDIDOSYA_WEBHOOK_SECRET=""

# ─── Public ───
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="vladi-burger"
