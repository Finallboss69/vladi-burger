generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth & Users ───

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  passwordHash  String
  role          String   @default("CUSTOMER") // CUSTOMER, ADMIN, KITCHEN, DELIVERY
  loyaltyPoints Int      @default(0)
  vipLevel      String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders          Order[]
  addresses       Address[]
  burgerCreations BurgerCreation[]
  photos          CustomerPhoto[]
  photoLikes      PhotoLike[]
  reviews         OrderReview[]
  stampCard       StampCard?
}

// ─── Products ───

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  imageUrl    String?
  categoryId  String
  stock       Int      @default(-1) // -1 = unlimited
  isActive    Boolean  @default(true)
  isCombo     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category       @relation(fields: [categoryId], references: [id])
  extras     ProductExtra[]
  comboItems ComboItem[]
  orderItems OrderItem[]
}

model ProductExtra {
  id        String @id @default(cuid())
  name      String
  price     Float
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ComboItem {
  id        String  @id @default(cuid())
  name      String
  quantity  Int     @default(1)
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─── Ingredients (Custom Burger Builder) ───

model Ingredient {
  id       String  @id @default(cuid())
  name     String
  price    Float
  type     String // BUN, MEAT, CHEESE, VEGETABLE, SAUCE, TOPPING
  imageUrl String?
  isActive Boolean @default(true)
}

// ─── Orders ───

model Order {
  id             String   @id @default(cuid())
  orderNumber    Int      @unique
  userId         String
  status         String   @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, DELIVERING, DELIVERED, CANCELLED
  subtotal       Float
  discount       Float    @default(0)
  total          Float
  couponCode     String?
  deliveryType   String   @default("DELIVERY") // DELIVERY, PICKUP
  addressId      String?
  scheduledAt    DateTime?
  notes          String?
  pointsEarned   Int      @default(0)
  pointsRedeemed Int      @default(0)
  paymentId      String?
  paymentStatus  String?
  source         String   @default("WEB") // WEB, RAPPI, PEDIDOSYA
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  address          Address?          @relation(fields: [addressId], references: [id])
  items            OrderItem[]
  review           OrderReview?
  deliveryLocation DeliveryLocation?
}

model OrderItem {
  id                String  @id @default(cuid())
  orderId           String
  productId         String?
  name              String
  price             Float
  quantity          Int
  extras            String? // JSON string of extras
  isCustom          Boolean @default(false)
  customIngredients String? // JSON string of custom ingredients
  notes             String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model OrderReview {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

// ─── Delivery Location Tracking ───

model DeliveryLocation {
  id        String   @id @default(cuid())
  orderId   String   @unique
  lat       Float
  lng       Float
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Addresses ───

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  street    String
  number    String
  floor     String?
  apartment String?
  city      String
  zipCode   String
  lat       Float?
  lng       Float?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── Coupons ───

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Float
  isPercent Boolean   @default(true)
  minOrder  Float     @default(0)
  maxUses   Int       @default(100)
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// ─── Loyalty (Stamp Card: buy N burgers, get a prize) ───

model StampConfig {
  id              String  @id @default(cuid())
  stampsRequired  Int     @default(5)  // How many burgers to buy
  prizeName       String  @default("Vladi Burger Gratis") // What they win
  prizeDescription String @default("Tu 6ta hamburguesa es gratis!")
  prizeProductId  String? // Optional: specific product as prize
  prizeDiscount   Float   @default(100) // % discount on prize (100 = free)
  isActive        Boolean @default(true)
  categoryId      String? // Which category counts (null = burgers only)
}

model StampCard {
  id          String   @id @default(cuid())
  userId      String
  stamps      Int      @default(0)
  completed   Int      @default(0) // How many times they've completed the card
  lastStampAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model LoyaltyReward {
  id          String  @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  type        String // DISCOUNT, FREE_PRODUCT, SHIPPING
  value       String // JSON
  imageUrl    String?
  isActive    Boolean @default(true)
}

// ─── Delivery Schedules ───

model DeliverySchedule {
  id          String  @id @default(cuid())
  dayOfWeek   Int // 0=Sunday, 6=Saturday
  startTime   String // "11:00"
  endTime     String // "23:00"
  slotMinutes Int    @default(30)
  maxOrders   Int    @default(5)
  isActive    Boolean @default(true)
}

// ─── Blog ───

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Community ───

model BurgerCreation {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  ingredients String // JSON: [{ingredientId, quantity, name}]
  totalPrice  Float
  voteCount   Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  userId     String
  imageUrl   String
  caption    String?
  isApproved Boolean  @default(false)
  likes      Int      @default(0)
  createdAt  DateTime @default(now())

  user      User        @relation(fields: [userId], references: [id])
  photoLikes PhotoLike[]
}

model PhotoLike {
  id      String @id @default(cuid())
  userId  String
  photoId String

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo CustomerPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
}
